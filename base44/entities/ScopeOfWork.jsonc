{
  "name": "ScopeOfWork",
  "type": "object",
  "properties": {
    "job_id": {
      "type": "string",
      "description": "ID of the associated Job"
    },
    "contractor_id": {
      "type": "string",
      "description": "ID of the contractor submitting the scope"
    },
    "contractor_name": {
      "type": "string",
      "description": "Name of the contractor"
    },
    "client_name": {
      "type": "string",
      "description": "Name of the client"
    },
    "client_email": {
      "type": "string",
      "description": "Email of the client"
    },
    "job_title": {
      "type": "string",
      "description": "Brief title of the work"
    },
    "client_scope_details": {
      "type": "string",
      "description": "Client's description of what needs to be done"
    },
    "client_scope_photo_urls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs of photos uploaded by client describing scope"
    },
    "scope_summary": {
      "type": "string",
      "description": "Contractor's detailed summary of the scope of work to be performed"
    },
    "cost_type": {
      "type": "string",
      "enum": [
        "hourly",
        "fixed"
      ],
      "description": "Whether the cost is hourly or a fixed total"
    },
    "cost_amount": {
      "type": "number",
      "description": "The hourly rate or fixed total cost"
    },
    "estimated_hours": {
      "type": "number",
      "description": "Estimated hours (if hourly)"
    },
    "agreed_work_date": {
      "type": "string",
      "format": "date",
      "description": "The date agreed between client and contractor for work to take place"
    },
    "after_photo_urls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs of after photos uploaded by contractor, required 72 hours after agreed work date"
    },
    "job_together_photo_url": {
      "type": "string",
      "description": "Photo of contractor and client together at the completed job site \u2014 used as the job thumbnail on both profiles"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending_approval",
        "approved",
        "rejected",
        "cancelled",
        "pending_ratings",
        "closed"
      ],
      "default": "pending_approval",
      "description": "Client approval status"
    },
    "client_notes": {
      "type": "string",
      "description": "Notes from the client on approval or rejection"
    },
    "client_signature_url": {
      "type": "string",
      "description": "URL of client's digital signature on the approved scope"
    },
    "client_signed_scope_at": {
      "type": "string",
      "description": "ISO timestamp when client signed/approved the scope"
    },
    "contractor_closeout_confirmed": {
      "type": "boolean",
      "default": false,
      "description": "Contractor has confirmed job closeout"
    },
    "client_closeout_confirmed": {
      "type": "boolean",
      "default": false,
      "description": "Client has confirmed job closeout (payment made, satisfied with work)"
    },
    "contractor_satisfaction_rating": {
      "type": "string",
      "enum": [
        "unsatisfactory",
        "satisfactory",
        "good",
        "excellent"
      ],
      "description": "Contractor's satisfaction rating of the client/engagement at closeout"
    },
    "client_satisfaction_rating": {
      "type": "string",
      "enum": [
        "unsatisfactory",
        "satisfactory",
        "good",
        "excellent"
      ],
      "description": "Client's satisfaction rating of the contractor's work at closeout"
    },
    "closed_date": {
      "type": "string",
      "description": "Date the job was officially closed out"
    },
    "contractor_email": {
      "type": "string",
      "description": "Email of the contractor"
    },
    "platform_fee_percentage": {
      "type": "number",
      "default": 18,
      "description": "Platform facilitation fee percentage (18%)"
    },
    "platform_fee_amount": {
      "type": "number",
      "description": "Calculated platform fee in dollars"
    },
    "contractor_payout_amount": {
      "type": "number",
      "description": "Final payout to contractor after platform fee"
    },
    "contract_id": {
      "type": "string",
      "description": "ID of the HomeImprovementContract being used (optional)"
    },
    "contract_status": {
      "type": "string",
      "enum": [
        "not_sent",
        "pending",
        "contractor_signed",
        "client_signed",
        "fully_signed",
        "declined"
      ],
      "default": "not_sent",
      "description": "Status of contract signature flow"
    },
    "contractor_signed_at": {
      "type": "string",
      "description": "ISO timestamp when contractor signed"
    },
    "client_signed_at": {
      "type": "string",
      "description": "ISO timestamp when client signed"
    },
    "signed_contract_url": {
      "type": "string",
      "description": "URL of the fully signed contract"
    },
    "contract_declined_reason": {
      "type": "string",
      "description": "Reason client declined to sign (if applicable)"
    },
    "notion_page_url": {
      "type": "string",
      "description": "URL of the linked Notion project page"
    },
    "notion_page_id": {
      "type": "string",
      "description": "ID of the linked Notion project page"
    },
    "game_session_id": {
      "type": "string",
      "description": "ID of the UserGameSession if a game discount was applied"
    },
    "game_discount_percentage": {
      "type": "number",
      "default": 0,
      "description": "Percentage discount earned from completing a game challenge"
    },
    "game_discount_applied": {
      "type": "boolean",
      "default": false,
      "description": "Whether a game discount has been applied to this scope"
    },
    "original_cost_amount": {
      "type": "number",
      "description": "Original cost before game discount was applied"
    }
  },
  "required": [
    "contractor_name",
    "client_name",
    "client_email",
    "job_title",
    "cost_type",
    "cost_amount"
  ],
  "rls": {
    "create": {
      "data.contractor_email": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "data.contractor_email": "{{user.email}}"
        },
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.contractor_email": "{{user.email}}"
        },
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.contractor_email": "{{user.email}}"
        },
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}