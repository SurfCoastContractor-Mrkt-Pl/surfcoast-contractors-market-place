{
  "name": "SMSConversation",
  "type": "object",
  "properties": {
    "contractor_id": {
      "type": "string",
      "description": "ID of the contractor in the conversation"
    },
    "contractor_email": {
      "type": "string",
      "description": "Email of the contractor"
    },
    "contractor_phone": {
      "type": "string",
      "description": "Phone number of the contractor"
    },
    "client_email": {
      "type": "string",
      "description": "Email of the client"
    },
    "client_phone": {
      "type": "string",
      "description": "Phone number of the client"
    },
    "client_name": {
      "type": "string",
      "description": "Name of the client"
    },
    "scope_id": {
      "type": "string",
      "description": "Associated ScopeOfWork ID (optional)"
    },
    "last_message": {
      "type": "string",
      "description": "Preview of the last message"
    },
    "last_message_time": {
      "type": "string",
      "description": "ISO timestamp of last message"
    },
    "unread_count": {
      "type": "number",
      "default": 0,
      "description": "Number of unread messages in this conversation"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ],
      "default": "active",
      "description": "Conversation status"
    }
  },
  "required": [
    "contractor_id",
    "contractor_email",
    "contractor_phone",
    "client_email",
    "client_phone",
    "client_name"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.contractor_email": "{{user.email}}"
        },
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "service_role"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.contractor_email": "{{user.email}}"
        },
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.contractor_email": "{{user.email}}"
        },
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.contractor_email": "{{user.email}}"
        },
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}