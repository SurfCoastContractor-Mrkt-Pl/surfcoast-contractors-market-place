{
  "name": "ClientScopeRequest",
  "type": "object",
  "properties": {
    "job_id": {
      "type": "string",
      "description": "ID of the associated Job"
    },
    "client_email": {
      "type": "string",
      "description": "Email of the client"
    },
    "client_name": {
      "type": "string",
      "description": "Name of the client"
    },
    "job_title": {
      "type": "string",
      "description": "Title of the job"
    },
    "scope_details": {
      "type": "string",
      "description": "Client's detailed description of what needs to be done"
    },
    "scope_photo_urls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs of photos uploaded by client describing the scope"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published",
        "archived"
      ],
      "default": "draft",
      "description": "Status of the scope request"
    }
  },
  "required": [
    "job_id",
    "client_email",
    "client_name",
    "job_title",
    "scope_details"
  ],
  "rls": {
    "create": {
      "data.client_email": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "id": {
            "$in": {
              "entity": "ContractorScopeProposal",
              "query": {
                "data.contractor_email": "{{user.email}}",
                "data.job_id": "$$this.job_id"
              },
              "field": "scope_request_id"
            }
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}