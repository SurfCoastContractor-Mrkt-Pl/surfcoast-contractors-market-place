{
  "name": "AgentReport",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string",
      "description": "Agent conversation ID"
    },
    "user_identifier": {
      "type": "string",
      "description": "Email or 'guest' if unauthenticated"
    },
    "issue_type": {
      "type": "string",
      "enum": [
        "bug",
        "platform_issue",
        "escalation",
        "feedback",
        "other"
      ],
      "description": "Type of reported issue"
    },
    "summary": {
      "type": "string",
      "description": "Brief summary of the issue reported"
    },
    "full_context": {
      "type": "string",
      "description": "Full context or transcript excerpt relevant to the issue"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium",
      "description": "Estimated severity of the issue"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "reviewed",
        "resolved",
        "dismissed"
      ],
      "default": "new",
      "description": "Admin review status"
    },
    "admin_notes": {
      "type": "string",
      "description": "Notes added by admin when reviewing"
    }
  },
  "required": [
    "summary",
    "issue_type"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "service_role"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}