{
  "name": "CRMInteraction",
  "type": "object",
  "properties": {
    "contractor_email": {
      "type": "string",
      "description": "Email of the contractor"
    },
    "crm_contact_id": {
      "type": "string",
      "description": "ID of the CRM contact"
    },
    "interaction_type": {
      "type": "string",
      "enum": ["call", "email", "message", "meeting", "job_completed", "quote_sent", "follow_up", "note"],
      "description": "Type of interaction"
    },
    "summary": {
      "type": "string",
      "description": "Summary of the interaction"
    },
    "outcome": {
      "type": "string",
      "description": "Result or next steps"
    },
    "interaction_date": {
      "type": "string",
      "description": "When the interaction occurred"
    }
  },
  "required": [
    "contractor_email",
    "crm_contact_id",
    "interaction_type",
    "summary"
  ],
  "rls": {
    "create": {
      "data.contractor_email": "{{user.email}}"
    },
    "read": {
      "$or": [
        { "data.contractor_email": "{{user.email}}" },
        { "user_condition": { "role": "admin" } }
      ]
    },
    "update": {
      "data.contractor_email": "{{user.email}}"
    },
    "delete": {
      "data.contractor_email": "{{user.email}}"
    }
  }
}