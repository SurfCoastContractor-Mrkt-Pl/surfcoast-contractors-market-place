{
  "name": "FAQArticle",
  "type": "object",
  "properties": {
    "question": {
      "type": "string",
      "description": "The FAQ question"
    },
    "answer": {
      "type": "string",
      "description": "The FAQ answer (supports markdown)"
    },
    "category": {
      "type": "string",
      "description": "Category or field of work this FAQ relates to"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Search tags for discoverability"
    },
    "is_published": {
      "type": "boolean",
      "default": true,
      "description": "Whether this FAQ is visible to the public"
    },
    "ai_generated": {
      "type": "boolean",
      "default": false,
      "description": "Whether this FAQ was generated by AI"
    },
    "last_ai_refresh": {
      "type": "string",
      "description": "ISO timestamp of last AI refresh"
    },
    "view_count": {
      "type": "number",
      "default": 0,
      "description": "Number of times this FAQ has been viewed"
    },
    "helpful_count": {
      "type": "number",
      "default": 0,
      "description": "Number of times marked helpful"
    },
    "sort_order": {
      "type": "number",
      "default": 0,
      "description": "Display order within category"
    }
  },
  "required": [
    "question",
    "answer",
    "category"
  ],
  "rls": {
    "create": {
      "$or": [
        { "user_condition": { "role": "admin" } },
        { "user_condition": { "role": "service_role" } }
      ]
    },
    "read": {},
    "update": {
      "$or": [
        { "user_condition": { "role": "admin" } },
        { "user_condition": { "role": "service_role" } }
      ]
    },
    "delete": {
      "user_condition": { "role": "admin" }
    }
  }
}